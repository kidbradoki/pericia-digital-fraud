# --- NOVAS FUNÇÕES DE PERÍCIA ---

def pericia_comprovante(nome, cpf_parcial, instituicao, chave):
    """Analisa dados extraídos de comprovantes de transferência."""
    print(f"\n--- 📑 RELATÓRIO DE PERÍCIA: {nome.upper()} ---")
    
    # 1. Análise de Região Fiscal (Baseado no 9º dígito do CPF)
    # Exemplo do PDF: XXX.812.877-XX -> O 9º dígito é 7
    digitos = "".join(filter(str.isdigit, cpf_parcial))
    regiao_info = "Desconhecida"
    if len(digitos) >= 9:
        nono_digito = digitos[8]
        mapa = {
            "1": "DF, GO, MS, MT, TO", "2": "AC, AM, AP, PA, RO, RR",
            "3": "CE, MA, PI", "4": "AL, PB, PE, RN", "5": "BA, SE",
            "6": "MG", "7": "ES, RJ", "8": "SP", "9": "PR, SC", "0": "RS"
        }
        regiao_info = mapa.get(nono_digito, "Não identificada")
    
    print(f"📍 ORIGEM DO CPF: {regiao_info} (Dígito {nono_digito if len(digitos)>=9 else '?'})")

    # 2. Análise da Instituição (Baseado no código do banco)
    # Celcoin (509) é uma IP (Instituição de Pagamento)
    inst_baixa = instituicao.lower()
    if "celcoin" in inst_baixa or "ip s.a" in inst_baixa or "pagamento" in inst_baixa:
        print("⚠️ ALERTA DE BANCO: Instituição de Pagamento digital. Alta incidência em contas de passagem.")
    else:
        print(f"🏦 INSTITUIÇÃO: {instituicao}")

    # 3. Análise do Tipo de Chave PIX
    if len(chave) > 30 and "-" in chave:
        print("🚩 TIPO DE CHAVE: Aleatória (EVP). Comum para ocultar identidade real (e-mail/telefone).")
    else:
        print(f"🔑 CHAVE UTILIZADA: {chave}")

    print("-" * 45)
    print(f"🔗 INVESTIGAR NOME: https://www.jusbrasil.com.br/consulta-processual/nome?q={nome.replace(' ', '+')}")

